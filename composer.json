{
    "name": "memran/marwa-mcp",
    "description": "Lightweight Model Context Protocol server library for Marwa Framework and standalone PHP apps.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "Memran\\MarwaMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Memran\\MarwaMcp\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/marwa-mcp"
    ],
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "analyse": "phpstan analyse -c phpstan.neon",
        "cs-check": "phpcs --standard=phpcs.xml",
        "cs-fix": "phpcbf --standard=phpcs.xml"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
